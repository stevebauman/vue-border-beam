{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@stevebauman/vue-border-beam": ["./src/index.ts"]
    }
  },
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue", "demo/**/*.ts", "demo/**/*.vue", "tests/**/*.ts"],
  "references": []
}
